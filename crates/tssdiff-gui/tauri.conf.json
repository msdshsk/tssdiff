{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tssdiff",
  "version": "0.2.0",
  "identifier": "dev.msdshsk.tssdiff",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "tssdiff",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 560,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "publisher": "msdshsk",
    "category": "DeveloperTool",
    "shortDescription": "Read-only git diff viewer with agent feedback",
    "longDescription": "tssdiff is a fast, read-only git diff viewer with side-by-side panes, history browsing, and inline feedback threads for AI coding agents.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Japanese", "English"]
      }
    }
  }
}
